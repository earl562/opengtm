{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutate": [
    "packages/connectors/src/mock.ts",
    "packages/skills/src/executor-binding.ts",
    "packages/skills/src/manifest-v2.ts",
    "packages/storage/src/migrate.ts",
    "packages/storage/src/paths.ts"
  ],
  "mutator": {
    "excludedMutations": [
      "StringLiteral",
      "OptionalChaining",
      "LogicalAnd"
    ]
  },
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 75
  },
  "testRunner": "vitest",
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": "always",
  "plugins": [
    "@stryker-mutator/vitest-runner"
  ],
  "reporters": [
    "progress",
    "clear-text",
    "html"
  ]
}
