{
  "name": "opengtm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "packages/*",
    "test"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mutation": "npx stryker run",
    "test:mutation:ci": "npx stryker run --reporter=junit --reporter-outfile=.artifacts/unit/junit.xml",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'Lint not configured yet'",
    "build": "tsup",
    "build:clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@stryker-mutator/core": "^9.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}