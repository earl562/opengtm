{
  "name": "opengtm",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "opengtm": "bin/opengtm.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "bin/**",
    "assets/**"
