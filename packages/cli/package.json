  "bugs": {
    "url": "https://github.com/earl562/opengtm/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
