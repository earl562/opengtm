  "files": [
    "dist/**",
    "bin/**"
  ],
  "dependencies": {
    "@opengtm/types": "0.1.0",
    "@opengtm/core": "0.1.0",
    "@opengtm/observability": "0.1.0",
    "@opengtm/storage": "0.1.0",
    "@opengtm/policy": "0.1.0",
    "@opengtm/daemon": "0.1.0",
    "@opengtm/evals": "0.1.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
