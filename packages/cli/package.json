{
  "name": "@opengtm/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "opengtm": "./bin/opengtm.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "bin/**"
  ],
  "dependencies": {
    "@opengtm/types": "file:../types",
    "@opengtm/core": "file:../core",
    "@opengtm/storage": "file:../storage",
    "@opengtm/policy": "file:../policy",
    "@opengtm/daemon": "file:../daemon"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}
